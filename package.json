{
  "name": "kozocom-mcp-google",
  "version": "0.1.0",
  "description": "Kozocom MCP server",
  "type": "module",
  "bin": {
    "kozocom-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "login": "node dist/login.js",
    "login:dev": "tsx src/login.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "modelcontextprotocol"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "googleapis": "^144.0.0",
    "open": "^10.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "oxlint": "^1.68.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
