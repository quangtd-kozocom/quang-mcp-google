{
  "name": "terra-mcp-google",
  "version": "0.1.16",
  "description": "Kozocom MCP server",
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22.5.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quangtd-kozocom/terra-mcp-google.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "terra-mcp": "dist/cli.js",
    "terra-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "scripts/install.sh"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/embed-oauth-client.mjs && node scripts/copy-admin.mjs",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/cli.js",
    "admin": "node dist/cli.js admin",
    "admin:dev": "tsx src/cli.ts admin",
    "admin:build": "pnpm -C admin install && pnpm -C admin build",
    "admin:ui:dev": "pnpm -C admin dev",
    "login": "node dist/cli.js auth login",
    "logout": "node dist/cli.js auth logout",
    "auth:status": "node dist/cli.js auth status",
    "setup": "node dist/cli.js setup",
    "client": "node dist/cli.js client",
    "login:dev": "tsx src/cli.ts auth login",
    "logout:dev": "tsx src/cli.ts auth logout",
    "auth:status:dev": "tsx src/cli.ts auth status",
    "setup:dev": "tsx src/cli.ts setup",
    "client:dev": "tsx src/cli.ts client",
    "release": "bash scripts/release.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "modelcontextprotocol"
  ],
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^15.0.0",
    "googleapis": "^144.0.0",
    "hono": "^4.12.24",
    "open": "^10.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "oxlint": "^1.68.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
